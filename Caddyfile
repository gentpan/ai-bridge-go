# AI Bridge Caddy 配置（自动 HTTPS）
# 替换 your-domain.com 为你的域名

your-domain.com {
    # 反向代理到 AI Bridge
    reverse_proxy ai-bridge:8080
    
    # 日志
    log {
        output file /data/access.log {
            roll_size 10MB
            roll_keep 10
        }
    }
    
    # 压缩
    encode gzip
    
    # 安全头
    header {
        # 禁用某些浏览器的 content type 嗅探
        X-Content-Type-Options nosniff
        # XSS 保护
        X-Frame-Options DENY
        X-XSS-Protection "1; mode=block"
        # 移除服务器标识
        -Server
    }
}

# 如果你有多个域名
# api.your-domain.com {
#     reverse_proxy ai-bridge:8080
# }
